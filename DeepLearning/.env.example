# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=raw-sensor-data
KAFKA_FEATURES_TOPIC=prepared-ml-features
KAFKA_PREDICTIONS_TOPIC=ml-predictions
KAFKA_DLQ_TOPIC=raw-sensor-data-dlq

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Model Configuration
MODEL_PATH=models/time_series_lstm.keras
MODEL_VERSION=1.0
WINDOW_SIZE=24

# Service Configuration
LOG_LEVEL=INFO
BATCH_SIZE=32
PREDICTION_TIMEOUT=5

# AWS Configuration (if deploying to AWS)
AWS_REGION=us-east-1
AWS_S3_BUCKET=ml-models-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# RabbitMQ Configuration (optional)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Azure Service Bus Configuration (optional)
AZURE_SERVICE_BUS_CONNECTION_STRING=
