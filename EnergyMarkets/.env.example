# Database Configuration
DATABASE_URL=postgresql+asyncpg://trader_admin:SecureTradingPassword2026!@localhost:5432/power_db

# ENTSO-E API Configuration
# Get your API key from: https://transparency.entsoe.eu/
# Email transparency@entsoe.eu with your account email to request a token
ENTSOE_API_KEY=your_entsoe_api_key_here

# Nord Pool API Configuration
# Contact Nord Pool commercial team for API subscription
NORDPOOL_API_KEY=your_nordpool_api_key_here

# Grafana Configuration
GF_SECURITY_ADMIN_PASSWORD=admin_grafana_pass
GF_USERS_ALLOW_SIGN_UP=false

# PostgreSQL/TimescaleDB Configuration
POSTGRES_USER=trader_admin
POSTGRES_PASSWORD=SecureTradingPassword2026!
POSTGRES_DB=power_db

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
